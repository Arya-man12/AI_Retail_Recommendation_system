APP_NAME=customer-intelligence-api
FRONTEND_ORIGIN=http://localhost:5173

# LangSmith observability
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=replace-me
LANGSMITH_PROJECT=customer-intelligence-copilot

# MLflow tracking
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=customer-intelligence-baselines

# Qdrant vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=customer_product_embeddings

# LLM policy guardrails
POLICY_BLOCK_PII=true
POLICY_REQUIRE_TOOL_RBAC=true
